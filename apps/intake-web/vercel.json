{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules/**,.next/**,**/*.png,**/*.zip}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/main" }
  ],
  "ignoreCommand": "git diff --quiet ${VERCEL_GIT_PREVIOUS_SHA:-HEAD^} ${VERCEL_GIT_COMMIT_SHA:-HEAD} -- :/apps/intake-web :/tsconfig.base.json :/package.json"
}
