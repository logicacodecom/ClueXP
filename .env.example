# Local Next.js -> FastAPI rewrite target.
LOCAL_API_BASE_URL=http://127.0.0.1:8000

# Production Supabase Postgres connection.
# For Vercel serverless Python, prefer Supabase transaction pooler on port 6543.
DATABASE_URL=postgres://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres

# API CORS allowlist (comma-separated). Unset falls back to "*" for local dev.
ALLOWED_ORIGINS=https://your-project.vercel.app

# Frontend (NEXT_PUBLIC_*) — safe to expose to the browser.
# Demo banner on fulfillment/payment screens; set to "false" once those are real.
NEXT_PUBLIC_DEMO_MODE=true
# Number the human-handoff "Call now" button dials.
NEXT_PUBLIC_DISPATCH_PHONE=+18005551234
